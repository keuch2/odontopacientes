# Con EAS_NO_VCS=1, EAS copia desde mobile-app/ usando .easignore con paths
# relativos a este directorio. Cualquier "../" se interpreta hacia el padre.

# Workspaces hermanos del monorepo
../backend/
../web-admin/
../shared/
../docs/
../scripts/

# Configuración del monorepo raíz que confunde a EAS
../.git/
../.github/
../.vscode/
../.idea/
../node_modules/
../*.json
../*.yaml
../*.md
../*.lock
../*.sh

# Asset pesado local que no necesita el build
mobile-app-backup/
imagenes_mobile/
mockups/
app-store-previews/
